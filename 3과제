metadata:
  name: apdev-ingress
  namespace: apdev
  annotations:
    kubernetes.io/ingress.class: alb
    alb.ingress.kubernetes.io/scheme: internet-facing
    alb.ingress.kubernetes.io/target-type: ip
    alb.ingress.kubernetes.io/subnets: <PUB_SUB1>,<PUB_SUB2>
    alb.ingress.kubernetes.io/security-groups: <ALB_SG>
    alb.ingress.kubernetes.io/healthcheck-path: /healthcheck
    alb.ingress.kubernetes.io/actions.return-404: >
      {"type":"fixed-response","fixedResponseConfig":{"contentType":"application/json","statusCode":"404","messageBody":"{\"message\":\"Not Found\"}"}}
