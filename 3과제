# DB 서브넷 그룹
aws rds create-db-subnet-group \
  --db-subnet-group-name apdev-rds-subnet-group \
  --db-subnet-group-description "apdev RDS subnet group" \
  --subnet-ids $PRI_SUB1 $PRI_SUB2

