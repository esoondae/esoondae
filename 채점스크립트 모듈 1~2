printf "${BOLD}${CYAN}║${RESET}  %-30s${BOLD}${CYAN}║${RESET}  ${M1_COLOR}%d / %d항목${RESET}  ${BOLD}${CYAN}║${RESET}  ${M1_COLOR}%s점 / 7.5점${RESET}          ${BOLD}${CYAN}║${RESET}\n" \
  "Module 1. NoSQL" "$M1_PASS" "$M1_TOTAL" "$M1_SCORE"

# Module 2 결과
M2_SCORE=$(echo "scale=1; $M2_PASS * 1.5" | bc 2>/dev/null || echo "0")
[ "$M2_PASS" = "$M2_TOTAL" ] && [ "$M2_TOTAL" -gt 0 ] && M2_COLOR="$GREEN" \
  || { [ "$M2_PASS" -gt 0 ] && M2_COLOR="$YELLOW" || M2_COLOR="$RED"; }
printf "${BOLD}${CYAN}║${RESET}  %-30s${BOLD}${CYAN}║${RESET}  ${M2_COLOR}%d / %d항목${RESET}  ${BOLD}${CYAN}║${RESET}  ${M2_COLOR}%s점 / 7.5점${RESET}          ${BOLD}${CYAN}║${RESET}\n" \
  "Module 2. CDN" "$M2_PASS" "$M2_TOTAL" "$M2_SCORE"

echo -e "${BOLD}${CYAN}╠══════════════════════════════╬══════════╬══════════════════════╣${RESET}"
printf "${BOLD}${CYAN}║${RESET}  %-30s${BOLD}${CYAN}║${RESET}  ${BOLD}%d / %d항목${RESET}  ${BOLD}${CYAN}║${RESET}  ${BOLD}%s점 / 15점${RESET}           ${BOLD}${CYAN}║${RESET}\n" \
  "합  계" "$GRAND_PASS" "$GRAND_TOTAL" "$GRAND_SCORE"
