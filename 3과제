2. 보안 그룹
# ALB 보안 그룹
ALB_SG=$(aws ec2 create-security-group --group-name apdev-alb-sg --description "ALB SG" --vpc-id $VPC_ID --query 'GroupId' --output text)
aws ec2 authorize-security-group-ingress --group-id $ALB_SG --protocol tcp --port 80 --cidr 0.0.0.0/0
aws ec2 authorize-security-group-ingress --group-id $ALB_SG --protocol tcp --port 443 --cidr 0.0.0.0/0

# EKS 노드 보안 그룹
NODE_SG=$(aws ec2 create-security-group --group-name apdev-node-sg --description "EKS Node SG" --vpc-id $VPC_ID --query 'GroupId' --output text)
aws ec2 authorize-security-group-ingress --group-id $NODE_SG --protocol tcp --port 8080 --source-group $ALB_SG
aws ec2 authorize-security-group-ingress --group-id $NODE_SG --protocol -1 --port -1 --source-group $NODE_SG

# RDS 보안 그룹
RDS_SG=$(aws ec2 create-security-group --group-name apdev-rds-sg --description "RDS SG" --vpc-id $VPC_ID --query 'GroupId' --output text)
aws ec2 authorize-security-group-ingress --group-id $RDS_SG --protocol tcp --port 3306 --source-group $NODE_SG

