  rules:
  - http:
      paths:
      - path: /v1/user
        pathType: Prefix
        backend:
          service:
            name: user-svc
            port:
              number: 8080
      - path: /v1/product
        pathType: Prefix
        backend:
          service:
            name: product-svc
            port:
              number: 8080
      - path: /v1/stress
        pathType: Prefix
        backend:
          service:
            name: stress-svc
            port:
              number: 8080
      - path: /healthcheck
        pathType: Exact
        backend:
          service:
            name: user-svc
            port:
              number: 8080
      - path: /
        pathType: Prefix
        backend:
          service:
            name: return-404
