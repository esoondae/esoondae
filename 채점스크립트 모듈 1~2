M2_TOTAL=$(echo "$M2_RESULT" | cut -d: -f2)

# 최종 집계
GRAND_PASS=$((M1_PASS + M2_PASS))
GRAND_TOTAL=$((M1_TOTAL + M2_TOTAL))
GRAND_SCORE=$(echo "scale=1; $GRAND_PASS * 1.5" | bc 2>/dev/null || echo "0")

