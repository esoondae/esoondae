echo -e "${BOLD}${CYAN}╠══════════════════════════════╬══════════╬══════════════════════╣${RESET}"

# Module 1 결과
M1_SCORE=$(echo "scale=1; $M1_PASS * 1.5" | bc 2>/dev/null || echo "0")
[ "$M1_PASS" = "$M1_TOTAL" ] && [ "$M1_TOTAL" -gt 0 ] && M1_COLOR="$GREEN" \
